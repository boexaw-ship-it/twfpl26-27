{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/twfpl26-27",
      "destination": "/index.html"
    },
    {
      "source": "/twfpl26-27/",
      "destination": "/index.html"
    },
    {
